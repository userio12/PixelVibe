# Built application files
*.apk
*.ap_
*.aab

# Files for the ART/Dalvik VM
*.dex

# Java class files
*.class

# Generated files
bin/
gen/
out/

# Gradle files
.gradle/
build/

# Local configuration file (sdk path, etc)
local.properties

# Proguard folder generated by Eclipse
proguard/

# Log Files
*.log

# Android Studio Navigation editor temp files
.navigation/

# Android Studio captures folder
captures/

# IntelliJ
*.iml
.idea/
workspace.xml
tasks.xml
caches/

# Keystore files (NEVER commit release keystores!)
*.keystore
*.jks
!app/debug.keystore
app/release/

# External native build folder generated in Android Studio 2.2 and later
.externalNativeBuild
.cxx/

# OS-specific files
.DS_Store
Thumbs.db

# Reference project (large, not needed in repo)
reference/

# Crash reports
app/src/main/assets/crashes/

# Temporary files
*.tmp
*.temp
*.swp
*.swo
*~

# Signed APKs
*.apks
*.apkm

# Version control
.svn/

# CI artifacts
dependency-report.txt
